{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "toolset": {
                "value": "ClangCL",
                "strategy": "set"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-x64-windows.cmake",
                "MATH_UTILS_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "windows-x64-debug",
            "displayName": "Windows x64 Debug",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/windows-x64-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "MATH_UTILS_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "windows-x64-release",
            "displayName": "Windows x64 Release",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/windows-x64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "MATH_UTILS_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "windows-x64-analysis",
            "displayName": "Windows x64 Static Analysis (clang-tidy)",
            "inherits": "windows-x64-debug",
            "binaryDir": "${sourceDir}/build/windows-x64-analysis",
            "cacheVariables": {
                "MATH_UTILS_ENABLE_CLANG_TIDY": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-x64-debug",
            "configurePreset": "windows-x64-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-x64-release",
            "configurePreset": "windows-x64-release",
            "configuration": "Release"
        },
        {
            "name": "windows-x64-analysis",
            "configurePreset": "windows-x64-analysis",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "windows-x64-debug",
            "configurePreset": "windows-x64-debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
